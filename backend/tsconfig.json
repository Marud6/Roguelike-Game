{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Declarations / maps */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Better DX */
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
